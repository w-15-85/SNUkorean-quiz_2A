<!DOCTYPE html>
<html lang="ko" translate="no">
<head>
  <meta charset="UTF-8" />
  <meta name="google" content="notranslate" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>서울대 한국어 2A - 중간고사 쓰기 연습</title>
  <style>
    :root {
      --main: #27ae60;
      --dark: #2c3e50;
      --blue: #3498db;
      --orange: #e67e22;
      --red: #e74c3c;
      --gray: #95a5a6;
      --bg: #f4f7f6;
    }

    body {
      font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif;
      margin: 0;
      padding: 20px;
      background: var(--bg);
      color: #243443;
      line-height: 1.75;
    }

    .wrap {
      max-width: 1050px;
      margin: 0 auto;
    }

    h1 {
      text-align: center;
      color: var(--dark);
      border-bottom: 4px solid var(--main);
      padding-bottom: 14px;
    }

    .card {
      background: #fff;
      border-radius: 16px;
      padding: 28px;
      box-shadow: 0 4px 18px rgba(0,0,0,.08);
      margin: 20px 0;
    }

    .menu-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .menu-card {
      background: #fff;
      border: 3px solid transparent;
      padding: 28px;
      border-radius: 16px;
      cursor: pointer;
      text-align: center;
      box-shadow: 0 3px 12px rgba(0,0,0,.06);
      transition: .2s;
    }

    .menu-card:hover {
      border-color: var(--main);
      transform: translateY(-2px);
    }

    .menu-card h2 {
      color: var(--main);
      margin-top: 0;
    }

    .btn {
      border: 0;
      border-radius: 9px;
      padding: 12px 22px;
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      margin: 6px;
    }

    .btn-main { background: var(--main); }
    .btn-blue { background: var(--blue); }
    .btn-orange { background: var(--orange); }
    .btn-gray { background: var(--gray); }

    .stage-title {
      background: var(--dark);
      color: #fff;
      padding: 14px;
      border-radius: 10px;
      text-align: center;
      font-weight: 800;
      font-size: 1.25rem;
      margin-bottom: 18px;
    }

    .grammar-box {
      background: #ecfff5;
      border-left: 6px solid var(--main);
      padding: 16px 20px;
      border-radius: 0 12px 12px 0;
      margin-bottom: 22px;
    }

    .grammar-box ul {
      margin: 8px 0 0 22px;
    }

    .q-block {
      border-left: 6px solid var(--main);
      background: #fbfdfc;
      padding: 20px 24px;
      margin: 22px 0;
      border-radius: 0 12px 12px 0;
    }

    .q-title {
      font-weight: 800;
      color: var(--main);
      font-size: 1.15rem;
      margin-bottom: 12px;
    }

    .q-text {
      font-size: 1.08rem;
    }

    .blank-input {
      border: 2px solid #cfd8dc;
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 1rem;
      min-width: 260px;
      margin: 4px 6px;
      font-weight: 700;
      color: #1f618d;
    }

    .blank-input.correct {
      border-color: var(--main);
      background: #f0fff6;
    }

    .blank-input.wrong {
      border-color: var(--red);
      background: #fff5f5;
    }

    .feedback {
      margin-top: 12px;
      padding: 12px;
      border-radius: 8px;
      display: none;
    }

    .feedback.ok {
      background: #ecfff5;
      color: #167a3a;
    }

    .feedback.no {
      background: #fff1f0;
      color: #b03a2e;
    }

    .result-table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }

    .result-table th,
    .result-table td {
      border: 1px solid #ddd;
      padding: 12px;
      text-align: center;
    }

    .result-table th {
      background: var(--dark);
      color: #fff;
    }

    .hidden {
      display: none;
    }

    textarea {
      width: 100%;
      min-height: 260px;
      border: 2px solid #cfd8dc;
      border-radius: 12px;
      padding: 15px;
      font-size: 1rem;
      line-height: 1.7;
      box-sizing: border-box;
    }

    select {
      padding: 10px;
      border-radius: 8px;
      border: 2px solid #cfd8dc;
      font-weight: 700;
    }

    .notice {
      color: #607d8b;
      font-size: .95rem;
    }

    .error-list li {
      margin: 5px 0;
    }

    @media(max-width:720px) {
      .menu-grid {
        grid-template-columns: 1fr;
      }

      .blank-input {
        width: 95%;
        min-width: 0;
      }
    }
  </style>
</head>

