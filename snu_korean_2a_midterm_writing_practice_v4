const writingTopics = [
  {
    lesson: "1과",
    title: "자기소개와 한국어 공부",
    prompt: "이름, 국적, 직업, 한국어를 배우는 이유를 쓰세요."
  },
  {
    lesson: "2과",
    title: "나의 취미",
    prompt: "자신의 취미와 할 줄 아는 것, 좋아하지 않는 것을 쓰세요."
  },
  {
    lesson: "3과",
    title: "기억에 남는 경험",
    prompt: "가 본 곳이나 해 본 활동을 기간 표현과 함께 쓰세요."
  },
  {
    lesson: "4과",
    title: "사고 싶은 옷",
    prompt: "사고 싶은 옷의 색깔, 사이즈, 가격, 바라는 점을 쓰세요."
  },
  {
    lesson: "5과",
    title: "추천하고 싶은 여행지",
    prompt: "추천하고 싶은 장소와 이유, 여행 계획을 쓰세요."
  },
  {
    lesson: "6과",
    title: "우체국이나 은행 이용",
    prompt: "편지, 소포, 환전, 송금 경험이나 방법을 쓰세요."
  },
  {
    lesson: "7과",
    title: "길 안내하기",
    prompt: "학교나 집 근처 장소에 가는 길을 설명하세요."
  },
  {
    lesson: "8과",
    title: "속상했던 일",
    prompt: "속상했던 일, 이유, 그때의 기분을 쓰세요."
  },
  {
    lesson: "9과",
    title: "문의하고 싶은 프로그램",
    prompt: "참가하고 싶은 프로그램에 대해 문의할 내용을 쓰세요."
  }
];

let currentLesson = 0;
let lessonScores = [];
let type2Try = 0;

function hideAll() {
  document.getElementById('mainMenu').classList.add('hidden');
  document.getElementById('type1Area').classList.add('hidden');
  document.getElementById('type2Area').classList.add('hidden');
}

function goMain() {
  hideAll();
  document.getElementById('mainMenu').classList.remove('hidden');
  window.scrollTo(0, 0);
}

function startType1() {
  hideAll();
  currentLesson = 0;
  lessonScores = [];
  renderLessonIntro();
}

function renderLessonIntro() {
  const area = document.getElementById('type1Area');
  area.classList.remove('hidden');

  const lesson = lessons[currentLesson];

  area.innerHTML = `
    <div class="card">
      <div class="stage-title">${lesson.lesson} ${lesson.title}</div>
      <div class="grammar-box">
        <strong>이번 단원에서 참고할 문법</strong>
        <ul>
          ${lesson.grammar.map(g => `<li>${g}</li>`).join('')}
        </ul>
      </div>
      <p>
        대화 지문 2영역, 읽기 지문 2영역을 풉니다.
        각 단원은 총 12문항이며, 9문항 이상 맞아야 다음 단원으로 갈 수 있습니다.
      </p>
      <div style="text-align:center;">
        <button class="btn btn-gray" onclick="${currentLesson === 0 ? 'goMain()' : 'goPrevLesson()'}">← 뒤로 가기</button>
        <button class="btn btn-main" onclick="renderLessonQuiz()">문제 시작하기 →</button>
      </div>
    </div>
  `;

  window.scrollTo(0, 0);
}

function goPrevLesson() {
  currentLesson = Math.max(0, currentLesson - 1);
  renderLessonIntro();
}

function renderTextWithInputs(text, baseId) {
  let idx = 0;
  return text.replace(/([①②③])/g, mark => {
    const html = `${mark}<input class="blank-input" id="${baseId}-${idx}" placeholder="${mark}번 빈칸" autocomplete="off">`;
    idx++;
    return html;
  });
}

function renderLessonQuiz() {
  const area = document.getElementById('type1Area');
  const lesson = lessons[currentLesson];

  let html = `
    <div class="card">
      <div class="stage-title">${lesson.lesson} ${lesson.title} - 유형 1 쓰기</div>
      <div class="grammar-box">
        <strong>참고 문법</strong>
        <ul>
          ${lesson.grammar.map(g => `<li>${g}</li>`).join('')}
        </ul>
      </div>
  `;

  lesson.groups.forEach((group, gi) => {
    html += `
      <div class="q-block">
        <div class="q-title">${group.section}</div>
    `;

    group.items.forEach((item, ii) => {
      const baseId = `q-${gi}-${ii}`;
      html += `
        <div class="q-text">${renderTextWithInputs(item.text, baseId)}</div>
        <div id="fb-${baseId}" class="feedback"></div>
      `;
    });

    html += `</div>`;
  });

  html += `
      <div style="text-align:center;">
        <button class="btn btn-gray" onclick="renderLessonIntro()">← 뒤로 가기</button>
        <button class="btn btn-blue" onclick="submitLesson()">↵ 제출하기</button>
      </div>
    </div>
  `;

  area.innerHTML = html;
  window.scrollTo(0, 0);
}

function submitLesson() {
  const lesson = lessons[currentLesson];
  let total = 0;
  let correct = 0;
  let empty = false;

  lesson.groups.forEach((group, gi) => {
    group.items.forEach((item, ii) => {
      const baseId = `q-${gi}-${ii}`;

      item.answers.forEach((ans, ai) => {
        total++;
        const value = document.getElementById(`${baseId}-${ai}`).value.trim();
        if (!value) empty = true;
      });
    });
  });

  if (empty) {
    alert('모든 빈칸에 답을 쓰세요.');
    return;
  }

  lesson.groups.forEach((group, gi) => {
    group.items.forEach((item, ii) => {
      const baseId = `q-${gi}-${ii}`;
      const wrongList = [];

      item.answers.forEach((ans, ai) => {
        const input = document.getElementById(`${baseId}-${ai}`);
        const value = input.value.trim();
        const allowed = Array.isArray(ans) ? ans : [ans];

        if (allowed.includes(value)) {
          correct++;
          input.classList.add('correct');
        } else {
          input.classList.add('wrong');
          wrongList.push(`${['①','②','③'][ai]} 정답: ${allowed[0]}`);
        }

        input.disabled = true;
      });

      const fb = document.getElementById(`fb-${baseId}`);
      fb.innerHTML = wrongList.length
        ? '오답 확인:<br>' + wrongList.join('<br>')
        : '모두 정답입니다.';
      fb.className = 'feedback ' + (wrongList.length ? 'no' : 'ok');
      fb.style.display = 'block';
    });
  });

  const passScore = Math.ceil(total * 0.7);
  const pass = correct >= passScore;

  lessonScores[currentLesson] = {
    lesson: lesson.lesson,
    title: lesson.title,
    correct,
    total,
    pass
  };

  const resultBox = document.createElement('div');
  resultBox.className = 'card';
  resultBox.innerHTML = `
    <div class="stage-title" style="background:${pass ? '#27ae60' : '#e74c3c'};">
      ${pass ? '통과' : '다시 풀기 필요'}: ${correct} / ${total}
    </div>
    <p style="text-align:center;font-weight:bold;">통과 기준: ${passScore}문항 이상 정답</p>
    <div style="text-align:center;">
      ${
        pass
          ? (
              currentLesson < lessons.length - 1
                ? '<button class="btn btn-main" onclick="nextLesson()">다음 단원으로 →</button>'
                : '<button class="btn btn-main" onclick="showType1Report()">결과 보기 📊</button>'
            )
          : '<button class="btn btn-orange" onclick="renderLessonQuiz()">↻ 다시 풀기</button>'
      }
      <button class="btn btn-gray" onclick="goMain()">🏠 메뉴로 가기</button>
    </div>
  `;

  document.getElementById('type1Area').appendChild(resultBox);
  resultBox.scrollIntoView({ behavior: 'smooth' });
}

function nextLesson() {
  currentLesson++;
  renderLessonIntro();
}

function showType1Report() {
  let rows = '';
  let totalCorrect = 0;
  let totalQuestions = 0;

  lessons.forEach((lesson, i) => {
    const score = lessonScores[i] || {
      correct: 0,
      total: 12,
      pass: false
    };

    totalCorrect += score.correct;
    totalQuestions += score.total;

    rows += `
      <tr>
        <td>${lesson.lesson}</td>
        <td>${lesson.title}</td>
        <td>${score.correct} / ${score.total}</td>
        <td>${Math.round(score.correct / score.total * 100)}%</td>
        <td>${score.pass ? '통과' : '미통과'}</td>
      </tr>
    `;
  });

  document.getElementById('type1Area').innerHTML = `
    <div class="card">
      <div class="stage-title">📊 유형 1 최종 결과</div>
      <table class="result-table">
        <thead>
          <tr>
            <th>단원</th>
            <th>제목</th>
            <th>점수</th>
            <th>백분율</th>
            <th>결과</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
      <div class="stage-title" style="background:#27ae60;">
        전체: ${totalCorrect} / ${totalQuestions} (${Math.round(totalCorrect / totalQuestions * 100)}%)
      </div>
      <div style="text-align:center;">
        <button class="btn btn-gray" onclick="goMain()">🏠 메뉴로 가기</button>
      </div>
    </div>
  `;

  window.scrollTo(0, 0);
}

function openType2() {
  hideAll();
  type2Try = 0;

  const area = document.getElementById('type2Area');
  area.classList.remove('hidden');

  area.innerHTML = `
    <div class="card">
      <div class="stage-title">유형 2 - 긴 글쓰기 연습</div>

      <label><strong>쓰기 주제 선택: </strong></label>
      <select id="topicSelect">
        ${writingTopics.map((topic, i) => `
          <option value="${i}">${topic.lesson} - ${topic.title}</option>
        `).join('')}
      </select>

      <div id="topicGuide" class="grammar-box" style="margin-top:18px;"></div>

      <textarea id="essay" placeholder="200~300자(띄어쓰기 포함)로 쓰세요."></textarea>
      <p id="charCount" class="notice">0자</p>

      <div style="text-align:center;">
        <button class="btn btn-gray" onclick="goMain()">← 뒤로 가기</button>
        <button class="btn btn-blue" onclick="checkEssay()">↵ 제출하기</button>
        <button class="btn btn-orange" onclick="openSpellChecker()">맞춤법 검사기 열기 ↗</button>
      </div>

      <div id="essayResult"></div>
    </div>
  `;

  document.getElementById('topicSelect').onchange = updateTopicGuide;
  document.getElementById('essay').oninput = () => {
    document.getElementById('charCount').innerText =
      document.getElementById('essay').value.length + '자';
  };

  updateTopicGuide();
  window.scrollTo(0, 0);
}

function updateTopicGuide() {
  const selected = document.getElementById('topicSelect').value;
  const topic = writingTopics[selected];

  document.getElementById('topicGuide').innerHTML = `
    <strong>${topic.lesson} ${topic.title}</strong><br>
    ${topic.prompt}
  `;
}

function checkEssay() {
  const text = document.getElementById('essay').value;
  const len = text.length;
  const errors = [];

  if (len < 200 || len > 300) {
    errors.push(`분량: 현재 ${len}자입니다. 200~300자로 쓰세요.`);
  }

  if (/그리고 그리고|저는 저는|그래서 그래서/.test(text)) {
    errors.push('같은 접속어나 주어가 반복된 곳이 있습니다.');
  }

  if (/[.!?]{2,}|[가-힣][.][가-힣]/.test(text)) {
    errors.push('문장 부호와 문장 사이 띄어쓰기를 확인하세요.');
  }

  if (/\s{3,}/.test(text)) {
    errors.push('불필요하게 긴 공백이 있습니다.');
  }

  if (!/[.?!요다]$/.test(text.trim())) {
    errors.push('마지막 문장의 종결 표현을 확인하세요.');
  }

  const result = document.getElementById('essayResult');
  type2Try++;

  if (!errors.length) {
    result.innerHTML = `
      <div class="feedback ok" style="display:block;">
        기본 점검을 통과했습니다. 교사가 최종 내용을 확인하세요.
      </div>
    `;
    return;
  }

  let html = `
    <div class="feedback no" style="display:block;">
      <strong>수정할 부분</strong>
      <ul class="error-list">
        ${errors.map(error => `<li>${error}</li>`).join('')}
      </ul>
  `;

  if (type2Try >= 2) {
    const topic = writingTopics[document.getElementById('topicSelect').value];

    html += `
      <hr>
      <strong>참고 답안 방향</strong>
      <p>
        ${topic.prompt} 주제에 맞게 먼저 상황을 소개하고,
        이유 두 가지와 자신의 생각을 200~300자로 정리하세요.
        문장은 짧게 쓰고, 한 문장에 한 가지 정보만 쓰세요.
      </p>
    `;
  }

  html += `</div>`;
  result.innerHTML = html;
}

function openSpellChecker() {
  const text = document.getElementById('essay').value;

  if (navigator.clipboard) {
    navigator.clipboard.writeText(text);
  }

  window.open(
    'https://search.naver.com/search.naver?query=%EB%84%A4%EC%9D%B4%EB%B2%84%20%EB%A7%9E%EC%B6%A4%EB%B2%95%20%EA%B2%80%EC%82%AC%EA%B8%B0',
    '_blank'
  );
}
</script>
</body>
